# =============================================================================
# Arrgo — Environment Configuration
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# =============================================================================


# -----------------------------------------------------------------------------
# Core (Required)
# -----------------------------------------------------------------------------

# PostgreSQL connection string. Uses the arrgo-db service name by default.
DATABASE_URL=postgres://arrgo:changeme@arrgo-db:5432/arrgo?sslmode=disable

# Random secret used to sign session cookies. Generate with: openssl rand -hex 32
SESSION_SECRET=

# Initial admin account credentials (seeded on first run)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
ADMIN_EMAIL=admin@arrgo.local

# API keys for metadata providers
TMDB_API_KEY=
TVDB_API_KEY=


# -----------------------------------------------------------------------------
# Database (arrgo-db service)
# -----------------------------------------------------------------------------

POSTGRES_USER=arrgo
POSTGRES_PASSWORD=changeme
POSTGRES_DB=arrgo


# -----------------------------------------------------------------------------
# Media Paths
# -----------------------------------------------------------------------------

# Root of your media share. Map this to /data inside the container.
MEDIA_PATH=/mnt/user/media

# Paths inside the container (relative to the /data mount above)
MOVIES_PATH=/data/movies
SHOWS_PATH=/data/shows
INCOMING_MOVIES_PATH=/data/incoming/movies
INCOMING_SHOWS_PATH=/data/incoming/shows


# -----------------------------------------------------------------------------
# qBittorrent / VPN
# -----------------------------------------------------------------------------

QBITTORRENT_URL=http://arrgo-qbittorrent:8080
QBITTORRENT_USER=
QBITTORRENT_PASS=

# PIA credentials for the binhex VPN container
PIA_USER=
PIA_PASSWORD=

# Your LAN subnet — used by the VPN container to allow local traffic through
LAN_NETWORK=192.168.1.0/24

VPN_ENABLED=yes
VPN_PROV=pia


# -----------------------------------------------------------------------------
# Jellyfin (Optional)
# -----------------------------------------------------------------------------

# Leave blank to disable Jellyfin integration entirely
JELLYFIN_URL=http://jellyfin:8096
JELLYFIN_API_KEY=


# -----------------------------------------------------------------------------
# Subtitles (Optional)
# -----------------------------------------------------------------------------

OPENSUBTITLES_API_KEY=
OPENSUBTITLES_USER=
OPENSUBTITLES_PASS=

# Set to true to enable automatic subtitle synchronization via ffsubsync
ENABLE_SUBSYNC=false
FFSUBSYNC_URL=http://ffsubsync-api:8080


# -----------------------------------------------------------------------------
# Indexer Service (port 5004)
# Arrgo runs its own Torznab-compatible indexer on port 5004. External apps
# (e.g. a standalone Sonarr/Radarr instance) can add it as a custom indexer
# at http://<host>:5004/api. Arrgo itself uses it internally automatically.
# -----------------------------------------------------------------------------

# Optional: require this key from external Torznab clients. Leave blank to allow open access.
TORZNAB_API_KEY=

# FlareSolverr URL — used to bypass Cloudflare on protected indexers (e.g. 1337x)
CLOUDFLARE_BYPASS_URL=http://host.docker.internal:8191


# -----------------------------------------------------------------------------
# Server / Unraid
# -----------------------------------------------------------------------------

# IP of your server — used to generate qBittorrent deep-links in the UI
SERVER_IP=192.168.1.100

PORT=5003
TZ=America/New_York

# Unraid default user/group IDs
PUID=99
PGID=100

# Log level: debug | info | warn | error
GOLOG_LOG_LEVEL=error
DEBUG=false
